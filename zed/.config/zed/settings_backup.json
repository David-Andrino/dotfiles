{
    // Theme & Appearance
    "edit_predictions": {
        "copilot": {
            "enable_next_edit_suggestions": true,
        },
        "provider": "copilot",
    },
    "agent_servers": {
        "claude": {
            "default_config_options": {
                "model": "qwen3-coder:30b",
            },
            "env": {
                "ANTHROPIC_BASE_URL": "http://192.168.10.244:11434",
                "ANTHROPIC_API_KEY": "ollama",
                "ANTHROPIC_AUTH_TOKEN": "ollama",
                "ANTHROPIC_DEFAULT_SONNET_MODEL": "qwen3-coder:30b",
                "ANTHROPIC_MODEL": "qwen3-coder:30b",
            },
        },
    },
    "agent": {
        "default_model": {
            "provider": "copilot_chat",
            "model": "gpt-5-mini",
            "enable_thinking": false,
            "effort": "high"
        },
        "favorite_models": [],
        "default_profile": "ask",
        "model_parameters": [],
    },
    "language_models": {
        "ollama": {
            "api_url": "http://192.168.10.244:11434",
        },
    },
    "ssh_connections": [
        {
            "host": "192.168.10.65",
            "username": "andrinod",
            "args": [],
            "projects": [
                {
                    "paths": [
                        "/home/andrinod"
                    ]
                },
                {
                    "paths": [
                        "/home/andrinod/nds/nds-core"
                    ]
                }
            ]
        },
        {
            "host": "216",
            "args": [],
            "projects": [
                {
                    "paths": [
                        "/home/andrinod"
                    ]
                },
                {
                    "paths": [
                        "/home/andrinod/fit/fit-integrated/./"
                    ]
                }
            ]
        }
    ],
    "which_key": {
        "delay_ms": 200,
        "enabled": true,
    },
    "theme": "Catppuccin Mocha",
    "icon_theme": "Zed (Default)",
    "ui_font_size": 16,
    "buffer_font_size": 18,
    "buffer_font_features": { "calt": true },
    "buffer_font_weight": 500,
    "cursor_blink": false,
    "cursor_shape": "bar",
    "tab_size": 4,
    "soft_wrap": "preferred_line_length",
    "preferred_line_length": 120,
    "show_whitespaces": "selection",
    "minimap": { "show": "never" },
    "vertical_scroll_margin": 5,
    "indent_guides": { "enabled": true },
    "inlay_hints": {
        "toggle_on_modifiers_press": {
            "control": true,
            "alt": true,
        },
    },

    // Editor behavior
    "vim_mode": true,
    "use_autoclose": true,
    "ensure_final_newline_on_save": true,
    "remove_trailing_whitespace_on_save": true,
    "format_on_save": "on",
    "linked_edits": true,

    // Vim
    "vim": {
        "cursor_shape": {
            "insert": "bar",
            "normal": "block",
            "visual": "block",
            "replace": "underline",
        },
        "use_system_clipboard": "never",
    },

    // Git
    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": { "enabled": true },
    },

    // Terminal
    "terminal": {
        "font_family": "ZedMono Nerd Font Mono", //"FiraCode Nerd Font Mono",
        "font_size": 16,
        "font_features": { "calt": true },
        "blinking": "terminal_controlled",
    },

    "lsp": {
        "clangd": {
            "binary": {
                "arguments": ["--function-arg-placeholders=0", "--clang-tidy", "--header-insertion=never"],
            },
        },
        // "texlab": {
        //     "settings": {
        //         "texlab": {
        //             "forwardSearch": {
        //                 "executable": "okular",
        //                 "args": ["--unique", "file:%p#src:%l%f"],
        //             },
        //         },
        //     },
        // },
    },
    "languages": {
        "C": {
            "tab_size": 4,
            "language_servers": ["clangd", "!c-language-server"],
        },
        "C++": {
            "tab_size": 4,
            "language_servers": ["clangd", "!c-language-server"],
        },
        "VHDL": {
            "tab_size": 4,
            "soft_wrap": "none",
        },
        "YAML": {
            "tab_size": 4,
        },
    },
}
