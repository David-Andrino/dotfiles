[
    // ── Suggestions / Autocomplete ────────────────────────────────
    {
        "context": "Editor && showing_completions",
        "bindings": {
            "tab": "editor::ConfirmCompletion",
        },
    },

    // ── Insert mode ───────────────────────────────────────────────
    {
        "context": "Editor && vim_mode == insert",
        "bindings": {
            "j k": "vim::NormalBefore",
            "J K": "vim::NormalBefore",
            "ctrl-c": "editor::Copy",
            "ctrl-v": "editor::Paste",
            "ctrl-s": "workspace::Save",
        },
    },

    // ── Normal mode ───────────────────────────────────────────────
    {
        "context": "Editor && vim_mode == normal",
        "bindings": {
            "tab": "pane::ActivateNextItem",
            "shift-tab": "pane::ActivatePreviousItem",
            "ctrl-h": "workspace::ActivatePaneLeft",
            "ctrl-l": "workspace::ActivatePaneRight",
            "ctrl-k": "workspace::ActivatePaneUp",
            "ctrl-j": "workspace::ActivatePaneDown",
            "ctrl-b": "workspace::ToggleLeftDock",
            "K": "editor::Hover",
            "J": "editor::JoinLines",

            // Tab navigation (mirrors ctrl+] / ctrl+[ from VSCode)
            "ctrl-]": "pane::ActivateNextItem",
            "ctrl-[": "pane::ActivatePreviousItem",

            // Multi-cursor
            "ctrl-alt-up": "editor::AddSelectionAbove",
            "ctrl-alt-down": "editor::AddSelectionBelow",
            "ctrl-alt-j": "editor::AddSelectionBelow",
            "ctrl-alt-k": "editor::AddSelectionAbove",
            "space a": "editor::AlignSelections",

            // ── space-r: Rename ───────────────────────────────────
            "space r": "editor::Rename",

            // ── space-q: Close ────────────────────────────────────
            "space q": "pane::CloseActiveItem",
            "space Q": "pane::CloseAllItems",

            // ── space-w: Wrap ─────────────────────────────────────
            "space w": "editor::ToggleSoftWrap",

            // ── space-f: Find ─────────────────────────────────────
            "space f f": "file_finder::Toggle",
            "space f g": "workspace::NewSearch",
            "space f s": "project_symbols::Toggle",
            "space f d": "editor::GoToDefinition",
            "space f r": "editor::FindAllReferences",
            "space f u": "editor::FindAllReferences",
            "space f a": "workspace::NewSearch",
            "space f o": "outline_panel::ToggleFocus",

            // ── space-b: Sidebar ──────────────────────────────────
            "space b b": "workspace::ToggleLeftDock",
            "space b f": "project_panel::ToggleFocus",
            "space b e": "project_panel::ToggleFocus",
            // "space b g": "scm_panel::ToggleFocus",
            // "space b x": "extensions::Install",
            "space b o": "outline_panel::ToggleFocus",
            "space b a": "workspace::ToggleLeftDock",
            // "space b c": "assistant::ToggleFocus",
            "space b q": "workspace::ToggleLeftDock",

            // ── space-p: Panels ───────────────────────────────────
            "space p p": "workspace::ToggleBottomDock",
            "space p t": "workspace::ToggleBottomDock",
            "space p r": "diagnostics::Deploy",

            // ── space-o: Open ─────────────────────────────────────
            "space o r": "projects::OpenRecent",
            "space o f": "workspace::Open",

            // ── space-t: Tasks / Build ────────────────────────────
            "space t t": "task::Spawn",
            "space t l": "task::Rerun",
            "space t b": ["task::Spawn", { "task_name": "CMake: Build (Debug)" }],
            "space t B": ["task::Spawn", { "task_name": "CMake: Build (Release)" }],
            "space t c": ["task::Spawn", { "task_name": "CMake: Configure (Debug)" }],
            "space t C": ["task::Spawn", { "task_name": "CMake: Configure (Release)" }],
            "space t r": ["task::Spawn", { "task_name": "CMake: Test" }],
            "space t x": ["task::Spawn", { "task_name": "CMake: Clean" }],

            // ── space-c: AI / Assistant ───────────────────────────
            "space c i": "assistant::InlineAssist",
            "space c c": "agent::ToggleFocus",

            // ── space-d: Debug ────────────────────────────────────
            "space d": "debugger::Start",

            // ── F-keys ────────────────────────────────────────────
            "f5": ["task::Spawn", { "task_name": "CMake: Build (Debug)" }],
            "ctrl-f5": ["task::Spawn", { "task_name": "CMake: Test" }],
        },
    },

    // ── Visual mode ───────────────────────────────────────────────
    {
        "context": "Editor && vim_mode == visual",
        "bindings": {
            "J": "editor::MoveLineDown",
            "K": "editor::MoveLineUp",
            "space r": "editor::Rename",
        },
    },

    // ── Project Panel (File Explorer) ─────────────────────────────
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "a": "project_panel::NewFile",
            "A": "project_panel::NewDirectory",
            // "r": "project_panel::RenameFile",
            "d": "project_panel::Delete",
            // "o": "project_panel::ToggleExpanded",
            "ctrl-l": "workspace::ActivatePaneRight",
        },
    },

    // ── Terminal ──────────────────────────────────────────────────
    {
        "context": "Terminal",
        "bindings": {
            "ctrl-k": "workspace::ActivatePaneUp",
            "escape": "workspace::ToggleBottomDock",
        },
    },

    // ── Global (no context) ───────────────────────────────────────
    {
        "context": "Workspace",
        "bindings": {
            "ctrl-]": "pane::ActivateNextItem",
            "ctrl-[": "pane::ActivatePreviousItem",
            "ctrl-shift-o": "project_symbols::Toggle",
        },
    },
    {
        "context": "VimControl && !menu",
        "bindings": {
            "space": null,
        },
    },
    {
        "context": "((vim_mode == helix_normal || vim_mode == helix_select) && !menu)",
        "bindings": {
            "ctrl-alt-o ctrl-alt-o": "editor::SelectLargerSyntaxNode",
        },
    },
    {
        "bindings": {
            "alt-o": "editor::SwitchSourceHeader",
        },
    },
    {
        "context": "Workspace",
        "unbind": {
            "ctrl-alt-j": "multi_workspace::ToggleWorkspaceSidebar",
        },
    },
    {
        "context": "AcpThread > Editor",
        "unbind": {
            "ctrl-alt-k": "agent::ToggleThinkingMode",
        },
    },
]
